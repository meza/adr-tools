{
  "name": "@meza/adr-tools",
  "version": "1.0.11",
  "exports": {
    ".": {
      "import": {
        "types": "dist/types/index.d.ts",
        "default": "dist/index.js"
      }
    }
  },
  "bin": {
    "adr": "dist/index.js"
  },
  "license": "GPL-3.0",
  "type": "module",
  "types": "dist/index.d.ts",
  "private": false,
  "scripts": {
    "prebuild": "node ./scripts/inject-version.mjs ./src/version.ts",
    "prepack": "node ./scripts/inject-version.mjs ./src/version.ts && tsc && yarn copy ",
    "copy": "copyfiles -u 1 ./src/templates/** ./dist",
    "build": "tsc && yarn copy",
    "start": "ts-node src/index.ts",
    "commit": "cz",
    "commitlint": "commitlint",
    "ci": "npm-run-all lint test",
    "ci:dev": "exit 0",
    "clean": "rimraf dist .cache/tsbuildinfo",
    "clean:all": "yarn clean && rm -rf node_modules .cache",
    "fix:lint": "biome check --fix",
    "lint:ci": "biome ci --reporter=github",
    "lint:tsc": "tsc --noEmit",
    "lint": "npm-run-all --parallel lint:*",
    "test": "npm-run-all test:unit test:e2e",
    "test:unit": "vitest --coverage",
    "test:e2e": "vitest --config vitest.config.e2e.ts",
    "prepare": "is-ci || lefthook install",
    "report": "exit 0",
    "semantic-release": "semantic-release",
    "release": "semantic-release"
  },
  "dependencies": {
    "@types/inquirer": "9.0.10",
    "@types/node": "24.13.3",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "core-js": "3.49.0",
    "inquirer": "14.0.2",
    "marked": "18.0.6",
    "open": "11.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@commitlint/prompt-cli": "21.2.0",
    "@faker-js/faker": "10.5.0",
    "@meza/adr-tools": "2.0.1",
    "@meza/biome": "1.1.3",
    "@ryansonshine/commitizen": "4.2.8",
    "@ryansonshine/cz-conventional-changelog": "3.3.4",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.9",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/uuid": "10.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "copyfiles": "2.4.1",
    "cross-env": "10.1.0",
    "install-deps-postmerge": "2.0.1",
    "is-ci": "4.1.0",
    "lefthook": "2.1.10",
    "lint-staged": "17.0.8",
    "mock-cwd": "1.0.0",
    "npm-run-all2": "9.0.2",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.5",
    "ts-node": "10.9.2",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "uuid": "14.0.1",
    "vitest": "4.1.10",
    "yarn": "1.22.22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/meza/adr-tools.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@ryansonshine/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true",
      "biome check --write --no-errors-on-unmatched",
      "biome check --write --organize-imports-enabled=false --no-errors-on-unmatched",
      "biome check --write --unsafe --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched",
      "biome lint --write --no-errors-on-unmatched"
    ]
  }
}
